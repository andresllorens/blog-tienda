---
const { whatsappUrl } = Astro.props;
---

<header id="header">
  <div class="header-top">
    <div class="container">
      <div class="row">
        <div class="header-top-right col-md-10 col-sm-12 position-static">
          <ul class="mobile-nav">
            <li style="display: flex; align-items: center;">
              <a href="/venta/" id="link-logo"></a>
            </li>
            <li>
              <div id="menu-icon-container">
                <div class="menu-icon">
                  <span class="line-1"></span>
                  <span class="line-2"></span>
                  <span class="line-3"></span>
                </div>
              </div>
            </li>
          </ul>

          <ul id="desktop-nav" class="">
            <li>
              <a href="/venta/" id="link-logo"></a>
            </li>
            <li id="categorias-btn">
              <a class="no-logo" style="cursor: pointer;">Categorias</a>
            </li>
            <li>
              <a
                href="/venta/marcas-celulares"
                class="no-logo">Celulares</a
              >
            </li>
            <li>
              <a
                href="/venta/smartwatch"
                class="no-logo">Smartwatch</a
              >
            </li>
            <li>
              <a
                href="/venta/auriculares"
                class="no-logo">Auriculares</a
              >
            </li>
          </ul>
          <a
            href={whatsappUrl}
            id="wpp-header-btn"
            class="cont-boton-wpp"
            target="_blank"
            onclick={`return trackHeaderWppClick('${whatsappUrl}');`}
          ></a>
          <script is:inline>
            function trackHeaderWppClick(url) {
              let opened = false;
              const openOnce = () => {
                if (opened) return;
                opened = true;
                if (typeof url !== "undefined" && url !== "") {
                  window.open(url, "_blank");
                }
              };

              // 1. Google Ads
              if (typeof window.gtag === "function") {
                window.gtag("event", "conversion", {
                  send_to: "AW-11427887911/_y2YCK7TsZgcEKf2nskq",
                  event_callback: function () {
                    // Callback de seguridad
                  },
                });
              }

              // 2. Meta (Facebook/Instagram)
              if (typeof window.fbq === "function") {
                window.fbq("track", "Contact", {
                  content_name: "Boton Flotante",
                  content_category: "Consulta Directa",
                });
              }

              // 3. Redirección con delay
              setTimeout(openOnce, 1000);
              return false;
            }
          </script>
        </div>
      </div>
      <div
        id="mobile_top_menu_wrapper"
        class="row hidden-md-up"
        style="display:none;"
      >
        <div class="js-top-menu mobile" id="_mobile_top_menu"></div>
        <div class="js-top-menu-bottom">
          <div id="_mobile_currency_selector"></div>
          <div id="_mobile_language_selector"></div>
          <div id="_mobile_contact_link"></div>
        </div>
      </div>
    </div>
  </div>

  <div id="arbol-cat">
    <div class="block-categories">
      <ul class="category-top-menu">
        <li>
          <a
            class="text-uppercase h6"
            href="/venta/productos">Tienda</a
          >
        </li>
        <li>
          <ul class="category-sub-menu">
            <li data-depth="0">
              <div>
                <a href="/venta/accesorios"
                  >Accesorios</a
                >
              </div>
            </li>
            <li data-depth="0">
              <div>
                <a href="/venta/auriculares"
                  >Auriculares</a
                >
              </div>
            </li>
            <li data-depth="0">
              <div>
                <a href="/venta/celulares"
                  >Celulares</a
                >
              </div>
            </li>
            <li data-depth="0">
              <div>
                <a href="/venta/consolas">Consolas</a
                >
              </div>
            </li>
            <li data-depth="0">
              <div>
                <a href="/venta/electrodomesticos"
                  >Electrodomesticos</a
                >
              </div>
            </li>
            <li data-depth="0">
              <div>
                <a href="/venta/notebooks"
                  >Notebooks</a
                >
              </div>
            </li>
            <li data-depth="0">
              <div>
                <a href="/venta/parlantes"
                  >Parlantes</a
                >
              </div>
            </li>
            <li data-depth="0">
              <div>
                <a href="/venta/smartwatch"
                  >Smartwatch</a
                >
              </div>
            </li>
            <li data-depth="0">
              <div>
                <a href="/venta/tablets">Tablets</a>
              </div>
            </li>
          </ul>
        </li>
      </ul>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const categoriasBtn = document.getElementById("categorias-btn");
      const arbolCat = document.querySelector("#arbol-cat .block-categories");

      categoriasBtn.addEventListener("click", (event) => {
        event.stopPropagation(); // Evita que el clic se propague hacia el documento
        arbolCat.classList.toggle("active"); // Agrega o quita la clase active
        categoriasBtn.classList.toggle("active"); // Agrega o quita la clase active
      });

      // Detecta clics fuera del elemento #arbol-cat .block-categories
      document.addEventListener("click", (event) => {
        if (
          !arbolCat.contains(event.target) &&
          !categoriasBtn.contains(event.target)
        ) {
          arbolCat.classList.remove("active");
          categoriasBtn.classList.remove("active");
        }
      });
    });
  </script>
</header>
