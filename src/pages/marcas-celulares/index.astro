        >
      </div>
      <div class="col-md-6">
        <img
          src="https://tecnolobbyx.com/tienda/img/cms/samsung-cel.png"
          alt="Celular Samsung"
          style="width: 100%; height: auto; max-height: 561px; object-fit: contain;"
          title="Celular Samsung"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </div>
    <div class="row banner-prod" style="justify-content: space-between;">
      <div class="col-md-6">
        <img
          src="https://tecnolobbyx.com/tienda/img/cms/motorola-cel.png"
          alt="Descripción de la imagen"
          style="width: 100%; height: auto; max-height: 561px; object-fit: contain; object-position: left;"
        />
      </div>
      <div class="col-md-6 box-prod padding-5">
        <p class="txt-medium marca">
          <img
            src="https://tecnolobbyx.com/tienda/img/cms/motorola.png"
            alt="Celular motorola"
            style="object-fit: contain; display: inline-block;"
            title="Celular motorola"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          Motorola
        </p>
        <br />
        <p class="txt-medium">Todas las Novedades en</p>
        <p class="txt-medium">Smartphones</p>
        <p class="txt-medium"><b>Motorola<b></b></b></p><b
          ><b>
            <a
              class="boton-ir"
              href="/celulares/motorola/"
              >Ir a Celulares</a
            >
          </b></b
        >
      </div>
    </div>
  </section></LayoutPrincipal
>
