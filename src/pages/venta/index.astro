        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">
          <p>¿Qué promociones y descuentos especiales ofrece LobbyX?</p>
          <p class="ver">+</p>
          <p class="no-ver oculto">-</p>
        </div>
        <div class="faq-answer">
          ¡Tenemos muchos beneficios para vos!
          <br /><br />
          Tenes el 30% Off sobre el precio de lista en Xiaomi, Samsung y Motorola
          en Teléfonos Celulares
          <br /><br />
          En iPhone tenes de regalo: Cargador, Funda y Protector de pantalla
          <br /><br />
          Contamos con días especiales de cuotas sin interes con Santander y otros
          bancos (Consulta los días disponibles)
          <br /><br />
          A demás contamos con ofertas y promociones especiales.
        </div>
      </div>
    </div>

    <script is:inline>
      const questions = document.querySelectorAll(".faq-question");

      questions.forEach((question) => {
        question.addEventListener("click", () => {
          const faqItem = question.parentElement;
          const answer = question.nextElementSibling;
          const plusSign = question.querySelector(".ver");
          const minusSign = question.querySelector(".no-ver");

          // Cierra otras respuestas abiertas y oculta otros signos
          document.querySelectorAll(".faq-item").forEach((item) => {
            if (item !== faqItem) {
              item.classList.remove("active");
              // Resetea los signos a "+"
              item.querySelector(".ver").classList.remove("oculto");
              item.querySelector(".no-ver").classList.add("oculto");
            }
          });

          // Alterna la clase 'active' en el ítem actual
          faqItem.classList.toggle("active");

          // Alterna los signos "+" y "-"
          if (faqItem.classList.contains("active")) {
            plusSign.classList.add("oculto");
            minusSign.classList.remove("oculto");
          } else {
            plusSign.classList.remove("oculto");
            minusSign.classList.add("oculto");
          }
        });
      });
    </script>
