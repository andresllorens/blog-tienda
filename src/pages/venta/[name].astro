---
import LayoutPrincipal from "../../layouts/LayoutPrincipal.astro";
import { getCategoryById } from "../../lib/prestashop";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const category = await getCategoryById(18);

  if (!category?.associations?.categories) {
    console.error("No se pudo cargar la categoría 18 para /venta/[name].");
    return [];
  }

  delete category.associations.products;

  const categories = category.associations.categories || [];

  category.associations.categories = [];

  for (const cat of categories) {
    if (!cat?.id) {
      continue;
    }

    const c = await getCategoryById(cat.id);
    if (c?.active === "1") {
      category.associations.categories.push(c);
    }
  }

  const paths: any[] = [];

  try {
    const name = category.link_rewrite;

    if (!name) {
      return [];
    }

    paths.push({
      params: {
        name: name,
      },
      props: {
        category: category,
      },
    });
  } catch (e) {
    console.error(`Error:`, e);
  }

  return paths;
}

// 2. Obtener la data específica para ESTA categoria
const { category } = Astro.props;

// Extraer variables del objeto category
const name = category.name;
const meta_description = category.meta_description;
---

<LayoutPrincipal title={name} meta_description={meta_description}>
  <div
    class="row product-container js-product-container"
    style="padding: 5% 1%;"
  >
    <section class="brands-section">
      <h1 class="section-title">Nuestras Marcas</h1>
      <div class="brands-grid">
        <a href="./celulares/apple" class="brand-card">
          <div class="brand-logo-wrapper">
            <Image
              src="https://tecnolobbyx.com/tienda/img/iphone.png"
              alt="Celulares Apple"
              width={600}
              height={600}
            />
          </div>
          <span class="brand-name">Ver iPhones</span>
        </a>
        <a href="./celulares/xiaomi" class="brand-card">
          <div class="brand-logo-wrapper">
            <Image
              src="https://tecnolobbyx.com/tienda/img/xiaomi.png"
              alt="Celulares Xiaomi"
              width={600}
              height={600}
            />
          </div>
          <span class="brand-name">Ver Redmi</span>
        </a>
        <a href="./celulares/samsung" class="brand-card">
          <div class="brand-logo-wrapper">
            <Image
              src="https://tecnolobbyx.com/tienda/img/samsung.png"
              alt="Celulares Samsung"
              width={600}
              height={600}
            />
          </div>
          <span class="brand-name">Ver Galaxy</span>
        </a>
        <a href="./celulares/motorola" class="brand-card">
          <div class="brand-logo-wrapper">
            <Image
              src="https://tecnolobbyx.com/tienda/img/motorola.png"
              alt="Celulares Motorola"
              width={600}
              height={600}
            />
          </div>
          <span class="brand-name">Ver Moto</span>
        </a>
        <a href="./celulares/infinix" class="brand-card">
          <div class="brand-logo-wrapper">
            <Image
              src="https://tecnolobbyx.com/tienda/img/infinix.png"
              alt="Celulares Infinix"
              width={600}
              height={600}
            />
          </div>
          <span class="brand-name">Ver Infinix</span>
        </a>
      </div>
      <div class="button-container">
        <a href="./celulares" class="btn-celulares"> Ver todos los celulares </a>
      </div>
    </section>
    <style>
      .brands-section {
        padding: 40px 20px;
        max-width: 1200px;
        margin: 0 auto;
      }

      .section-title {
        text-align: center;
        margin-bottom: 30px;
        font-weight: 700;
        color: #333;
      }

      /* Configuración de la cuadrícula */
      .brands-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 15px;
        width: 100%;
      }

      /* Cambio a 3 columnas en Desktop (768px o más) */
      @media (min-width: 768px) {
        .brands-grid {
          grid-template-columns: repeat(3, 1fr);
          gap: 25px;
        }
      }

      /* Estilo de la tarjeta individual */
      .brand-card {
        display: flex;
        flex: 0 1 calc(33.33% - 10px);
        min-width: 140px;
        box-sizing: border-box;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background: #fff;
        border: 1px solid #eee;
        border-radius: 12px;
        text-decoration: none;
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease;
      }

      .brand-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
        border-color: #007bff;
        flex: 0 1 calc(50% - 8px);
        min-width: 140px;
        box-sizing: border-box;
      }

      .brand-logo-wrapper {
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;
      }

      .brand-logo-wrapper img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        /* Filtro opcional para que los logos se vean uniformes */
        filter: grayscale(20%);
      }

      .brand-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: #333;
      }
      .button-container {
        display: flex;
        justify-content: center;
        width: 100%;
        margin-top: 20px; /* Espacio respecto al grid */
        padding: 0 15px; /* Para que no toque los bordes en móviles */
        box-sizing: border-box;
      }

      .btn-celulares {
        display: block;
        width: 100%;
        max-width: 400px; /* Ajusta esto según prefieras */
        padding: 15px 0;

        background: linear-gradient(90deg, #6a11cb, #a445ed, #6a11cb);
        background-size: 200% auto;
        background-position: left center;

        color: #fff !important;
        text-align: center;
        text-decoration: none;
        font-weight: 600;
        font-size: 1.1rem;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(106, 17, 203, 0.3);

        transition: transform .2s ease, background-position .5s ease;
            cursor: pointer;
            border: none;
      }

      .btn-celulares:hover {
        transform: scale(.98);
        background-position: right center;
      }
    </style>
  </div>
</LayoutPrincipal>
