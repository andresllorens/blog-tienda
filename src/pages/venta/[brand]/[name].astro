  <script>
    // @ts-nocheck
    // Recuperamos datos de Astro para usarlos en el cliente
    const PRODUCT_ID = "{id}";
    const CATEGORY_ID = parseInt("{categoryId}");

    // Grupos definidos en tu lógica [cite: 12, 13]
    const grupoA = [18, 50, 61, 62];
    const grupoB = [20, 17, 58];

    const formatCurrency = (value: number | bigint) =>
      new Intl.NumberFormat("es-AR", {
        style: "currency",
        currency: "ARS",
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(value);

    async function refreshPrices() {
      try {
        // 1. Obtener precio real de PrestaShop (puedes usar un endpoint de tu lib/prestashop o un proxy)
        // Ajusta la URL a tu endpoint real en DonWeb
        const response = await fetch(`/api/get-current-price?id=${PRODUCT_ID}`);
        const data = await response.json();
        const rawPrice = parseFloat(data.price);

        if (isNaN(rawPrice)) return;

        // 2. Re-calcular lógica de negocio [cite: 14, 15, 16, 17, 18, 19]
        let precioEfectivo = 0;
        let precioDebito = 0;
        let cuota3 = 0;
        let cuota6 = 0;
        let discountPercentEfectivo = CATEGORY_ID === 18 ? 30 : 20;

        if (grupoA.includes(CATEGORY_ID)) {
          precioEfectivo = rawPrice * 0.7;
          precioDebito = rawPrice * 0.95;
          cuota3 = (rawPrice * 1.1) / 3;
          cuota6 = (rawPrice * 1.15) / 6;
        } else if (grupoB.includes(CATEGORY_ID)) {
          precioEfectivo = rawPrice * 0.8;
          precioDebito = rawPrice * 0.8;
          cuota3 = rawPrice / 3;
          cuota6 = (rawPrice * 1.1) / 6;
        }

        // 3. Actualizar el DOM (Elementos visuales)
        const elEfectivo = document.getElementById("precio-efectivo-val");
        const elLista = document.getElementById("precio-lista-val");
        const elDescuento = document.getElementById("descuento-val");

        if (elEfectivo) elEfectivo.textContent = formatCurrency(precioEfectivo);
        if (elLista) elLista.textContent = formatCurrency(rawPrice);
        if (elDescuento)
          elDescuento.textContent = `-${discountPercentEfectivo}% OFF`;

        // Modal de Precios - Lista Completa [cite: 43]
        const modalPrices = document.querySelectorAll(".modal-precios .price");
        if (modalPrices.length > 0) {
          modalPrices[0].innerHTML = `${formatCurrency(precioEfectivo)} <span style="font-size: 15px;">-${discountPercentEfectivo}% OFF</span>`; // Efectivo [cite: 43]
          modalPrices[1].innerText = formatCurrency(rawPrice); // Deposito [cite: 45]
          modalPrices[2].innerText = `${formatCurrency(precioDebito)} - Debito`; // Debito [cite: 48]
          modalPrices[3].innerText = `${formatCurrency(precioDebito)} - Ualá Prepaga`; // Ualá [cite: 50]
          modalPrices[4].innerText = `${formatCurrency(precioDebito)} - Credito 1 Pago`; // 1 Pago [cite: 53]

          // Cuotas
          const cuota3Span = document.querySelector(
            '.modal-precios span[style*="color: rgb(30,159,195)"]',
          );
          if (cuota3Span) cuota3Span.innerText = formatCurrency(cuota3);

          // Para la cuota 6 necesitamos un selector específico o recorrer
          const allBlueSpans = document.querySelectorAll(
            '.modal-precios span[style*="color: rgb(30,159,195)"]',
          );
          if (allBlueSpans[1])
            allBlueSpans[1].innerText = formatCurrency(cuota6);
        }
      } catch (error) {
        console.error("Error actualizando precios en tiempo real:", error);
      }
    }

    // Ejecutar al cargar y tras transiciones de Astro [cite: 77]
    refreshPrices();
    document.addEventListener("astro:after-swap", refreshPrices);
  </script>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</LayoutPrincipal>
