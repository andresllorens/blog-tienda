---
import { getProducts } from "../../../lib/prestashop";
import LayoutPrincipal from "../../../layouts/LayoutPrincipal.astro";
import ModalPedido from "../../../components/ModalPedido.astro";
import { getImageUrl } from "../../../lib/utils";
import { Image } from "astro:assets";

// 1. Generar todas las rutas posibles en el momento del 'build'
export async function getStaticPaths() {
  const products = await getProducts();

  // Filtro inicial por activos y categoría 18 [cite: 20]
  const filteredProducts = products.filter((product) => {
    return product.active === "1" && product.id_category_default === "18";
  });

  const paths: any[] = [];

  for (const product of filteredProducts) {
    try {
      // Validamos que manufacturer_name exista para evitar errores de string [cite: 7]
      const brandName = product.manufacturer_name || "generico";
      const brandSlug = brandName
        .toLowerCase()
        .replace(/\s+/g, "-")
        .replace(/[^a-z0-9-]/g, "");

      paths.push({
        params: {
          brand: brandSlug,
          name: product.link_rewrite,
        },
        props: {
          product: product,
        },
      });
    } catch (e) {
      console.error(`Error procesando producto ID ${product.id}:`, e);
    }
  }

  return paths;
}

// Funcioines auxiliares
const formatCurrency = (value: number | bigint) =>
  new Intl.NumberFormat("es-AR", {
    style: "currency",
    currency: "ARS",
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(value);

// 2. Obtener la data específica para ESTE producto
const { product } = Astro.props;
if (!product) {
  return Astro.redirect("/404");
}

// Extraer variables del objeto product
const id = product.id;
const productSlug = product.link_rewrite;
const price = product.price ? parseFloat(product.price).toFixed(2) : "0.00";
const name = product.name ?? "Producto sin nombre";
const meta_description = product.meta_description ?? "";
const categoryId = parseInt(product.id_category_default);

// Precios
const rawPrice = parseFloat(price);
// Definimos variables de salida

let porcDescuento = "-30% OFF";
let precioEfectivo = rawPrice * 0.7;
let precioDebito = rawPrice * 0.95;

// 3 Cuotas con recargo del 12%
const precioRecargo3 = rawPrice * 1.12;
let cuota3 = precioRecargo3 / 3;

// 6 Cuotas con recargo del 1.17%
const precioRecargo6 = rawPrice * 1.17;
let cuota6 = precioRecargo6 / 6;

// 9 Cuotas con recargo del 30%
const precioRecargo9 = rawPrice * 1.3;
let cuota9 = precioRecargo9 / 9;

// 12 Cuotas con recargo del 35%
const precioRecargo12 = rawPrice * 1.35;
let cuota12 = precioRecargo12 / 12;

//Efectivo
const discountPercentEfectivo = categoryId === 18 ? 30 : 20;
const precioEfectivoNum = rawPrice * (1 - discountPercentEfectivo / 100);

//Imagenes
const mainImageId = product.id_default_image ?? null;
const mainImage = await getImageUrl(id, mainImageId);
const images = product.associations.images || [];

//Whatsapp
const nameForWhatsapp = name.replace(/ /g, "+");
const whatsappNumber = "5493513473549";
const whatsappUrl = `https://api.whatsapp.com/send/?phone=${whatsappNumber}&text=Hola+Lobbyx%21+Queria+consultarte+sobre+${nameForWhatsapp}&type=phone_number&app_absent=0`;

// Lógica para la imagen (PrestaShop usa una estructura de carpetas basada en el ID)

const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": name,
  "image": [mainImage],
  "description": meta_description,
  "sku": product.id.toString(),
  "brand": {
    "@type": "Brand",
    "name": product.manufacturer_name
  },
  "offers": {
    "@type": "Offer",
    "url": Astro.url.href,
    "priceCurrency": "ARS", // Ajustar según tu moneda
    "price": parseFloat(product.price).toFixed(2),
    "itemCondition": "https://schema.org/NewCondition",
  }
};
