---
import LayoutListado from "../../layouts/LayoutListado.astro";
import {
  getCategoryById,
  getProductsByCategory,
} from "../../lib/prestashop";
import { getImageUrl } from "../../lib/utils";

const category = await getCategoryById(10);

if (!category?.associations?.categories) {
  console.error("No se pudo cargar la categoría 10 para /accesorios.");
  return [];
}

// Fase 1: cargar productos reales de la categoría 10 y normalizar view model
const rawProducts = await getProductsByCategory(10, { activeOnly: true });

function parsePrice(raw) {
  if (raw === null || raw === undefined) return 0;
  const n = Number(raw);
  if (!Number.isNaN(n)) return n;
  const cleaned = String(raw)
    .replace(/\./g, "")
    .replace(/,/g, ".")
    .replace(/[^0-9.\-]/g, "");
  const f = parseFloat(cleaned);
  return Number.isNaN(f) ? 0 : f;
}

const productsView = (rawProducts || []).map((p, idx) => {
  const id = Number(p?.id ?? p?.id_product ?? 0);
  let name = "";
  if (typeof p?.name === "object") {
    const vals = Object.values(p.name);
    name = vals[0] ?? "";
  } else {
    name = p?.name ?? "";
  }

  const priceNum = parsePrice(
    p?.price ?? p?.price_amount ?? p?.price_tax_incl ?? 0,
  );
  const price_formatted =
    typeof p?.price === "string"
      ? p.price
      : new Intl.NumberFormat("es-AR", {
          style: "currency",
          currency: "ARS",
          maximumFractionDigits: 0,
        }).format(priceNum);

  // image
  let image = null;
  const imgId = p?.id_default_image ?? null;
  if (imgId && id) {
    image = getImageUrl(id, imgId);
  }

  const categoriesIds = (p?.associations?.categories || [])
    .map((c) => Number(c?.id ?? c))
    .filter(Boolean);

  const url = `/accesorios/${(p?.link_rewrite || "").toString()}/`;

  return {
    id,
    name,
    url,
    price: priceNum,
    price_formatted,
    image,
    categories: categoriesIds,
    relevance: idx,
    active: p?.active === "1" || p?.active === 1 || p?.active === true,
  };
});

const priceVals = productsView
  .map((x) => x.price)
  .filter((n) => typeof n === "number");
const priceMin = priceVals.length ? Math.min(...priceVals) : 0;
const priceMax = priceVals.length ? Math.max(...priceVals) : 0;
const _fmtCurrency = new Intl.NumberFormat("es-AR", {
  style: "currency",
  currency: "ARS",
  maximumFractionDigits: 0,
});
const priceMinFormatted = priceMin ? _fmtCurrency.format(priceMin) : "$0";
const priceMaxFormatted = priceMax ? _fmtCurrency.format(priceMax) : "$0";

// Extraer variables del objeto category
const name = category.name;
const meta_description = category.meta_description;

const whatsappUrl =
  "https://api.whatsapp.com/send/?phone=543513473549&text=Hola+Lobbyx%21+Queria+consultarte+sobre...&type=phone_number&app_absent=0";
---

<LayoutListado
  title={name}
  meta_description={meta_description}
  whatsappUrl={whatsappUrl}
>
  <div class="container">
    <div id="js-product-list-header">
      <div
        class="imagen-portada cat-Accesorios"
        style="display: flex; align-items: center;"
      >
        <img
          src="https://tecnolobbyx.com/tienda/img/categoria/Accesorios.png"
          alt="Banner de Accesorios"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <div class="texto-portada" style="width: 40%;">
          <p
            class="txt-medium negrita"
            style="   font-size: 64px;
                                                    line-height: 75px;
                                                    border-left: 4px solid;
                                                    padding-left: 15px;
                                                    border-image: linear-gradient(
                                                    to bottom,
                                                    #000000 0%,
                                                    #9747FF 27%,
                                                    #00D9FF 37%,
                                                    #07E1FF 66%,
                                                    #9F2EFF 77%,
                                                    #FE02FF 83%,
                                                    #FD02FF 99%) 1;"
          >
            Accesorios
          </p>
          <br />
          <p class="txt-medium thin" style="font-size: 24px;width: 75%;">
            Encontra Cargadores, Fuentes, Cables, Fundas y Mucho Más…
          </p>
        </div>
      </div>
      <div
        class="container-mobile"
        style="
                background-color: #333333;
                padding-top: 100px;
                background-image: url(https://tecnolobbyx.com/tienda/img/categoria/accesorios-mobile-banner-categoria.jpg);
                background-size: contain;
                height: 475px;
                background-position: bottom;
                background-repeat: no-repeat;
                "
      >
        <p
          class="txt-small thin"
          style="text-align: start; margin: 0 0 0 5vw; color: #FFF; font-size: 1rem;"
        >
          Las mejores ofertas en
        </p>
        <p
          class="txt-medium"
          style="
                margin: 0 0 0 5vw; color: #FFF; text-align: start; font-size: 1.75rem; font-weight: 600;"
        >
          ACCESORIOS
        </p>
        <p
          class="txt-small thin"
          style="text-align: start; margin: 0 0 0 5vw; color: #FFF; font-size: 1rem"
        >
          Encontra Cargadores, Fuentes, Cables, Fundas y Mucho Más…
        </p>
      </div>
    </div>

    <div id="left-column" class="col-xs-12 col-sm-4 col-md-3">
      <div id="search_filters_wrapper" class="hidden-sm-down">
        <div id="search_filters" style="margin: 0;">
          <p class="text-uppercase h6">Filtrar por</p>

          <section class="facet" data-type="price">
            <p class="h6 facet-title">Precio</p>
            <div class="filter-container">
              <div
                id="price-slider"
                style="margin: 20px 10px;"
                data-min={priceMin}
                data-max={priceMax}
              >
              </div>

              <p class="text-center" id="price-label">
                {priceMinFormatted} - {priceMaxFormatted}
              </p>
            </div>
          </section>
        </div>
      </div>
    </div>

    <div
      id="content-wrapper"
      class="js-content-wrapper left-column col-xs-12 col-sm-8 col-md-9"
    >
      <section id="main">
        <section id="products">
          <div id="js-product-list-top" class="row products-selection">
            <div class="col-md-6 hidden-sm-down total-products">
              <p>
                Hay {productsView.length}
                {productsView.length === 1 ? "producto" : "productos"}.
              </p>
            </div>
            <div class="col-md-6">
              <div class="row sort-by-row">
                <span class="col-sm-3 col-md-3 hidden-sm-down sort-by"
                  >Ordenar por:</span
                >
                <div class="col-sm-9 col-xs-12 col-md-9 products-sort-order">
                  <label for="products-sort-select" class="sr-only"
                    >Ordenar por</label
                  >
                  <select
                    id="products-sort-select"
                    class="products-sort-select"
                    aria-label="Ordenar por"
                    style="width: 100%;"
                  >
                    <option value="relevance">Relevancia</option>
                    <option value="name-asc">Nombre, A a Z</option>
                    <option value="name-desc">Nombre, Z a A</option>
                    <option value="price-asc"
                      >Precio: de más bajo a más alto</option
                    >
                    <option value="price-desc"
                      >Precio, de más alto a más bajo</option
                    >
                  </select>
                </div>
              </div>
            </div>
            <div class="col-sm-12 hidden-md-up text-sm-center showing">
              Mostrando 1-{productsView.length} de {productsView.length}
              {productsView.length === 1 ? "artículo" : "artículos"}
            </div>
          </div>

          <div id="js-product-list">
            <div class="products row">
              {
                productsView.map((producto) => (
                  <div
                    class="js-product product col-xs-12 col-sm-6 col-xl-4"
                    data-price={producto.price}
                    data-relevance={producto.relevance}
                  >
                    <article
                      class="product-miniature js-product-miniature"
                      data-id-product={producto.id}
                      data-id-product-attribute="0"
                    >
                      <div class="thumbnail-container reviews-loading">
                        <div class="thumbnail-top">
                          <a
                            href={producto.url}
                            class="thumbnail product-thumbnail"
                          >
                            <img
                              src={producto.image}
                              alt={producto.name}
                              loading="lazy"
                              width="250"
                              height="250"
                              style="padding-top: 85px;"
                            />
                          </a>
                        </div>

                        <div class="product-description">
                          <h2 class="h3 product-title">
                            <a href={producto.url}>{producto.name}</a>
                          </h2>

                          <div class="product-price-and-shipping">
                            <span class="price" aria-label="Precio">
                              $&nbsp;
                              {new Intl.NumberFormat("es-AR").format(
                                producto.price,
                              )}
                            </span>
                          </div>
                        </div>
                      </div>
                    </article>
                  </div>
                ))
              }
            </div>
            <nav class="mt-4">
              <ul
                id="pagination-container"
                class="pagination justify-content-center"
              >
              </ul>
            </nav>
          </div>
        </section>
      </section>
    </div>
  </div>
  <script type="module">
    import noUiSlider from "https://cdn.jsdelivr.net/npm/nouislider@15.8.1/dist/nouislider.mjs";
    // CSS is loaded via CDN link injected by Vite/ASTRO; keep import-free for runtime

    function initSlider() {
      const slider = document.getElementById("price-slider");
      const label = document.getElementById("price-label");

      if (!slider) return;

      let minVal = Number(slider.dataset.min);
      let maxVal = Number(slider.dataset.max);

      if (!Number.isFinite(minVal)) minVal = 0;
      if (!Number.isFinite(maxVal)) maxVal = minVal;
      if (minVal === maxVal) maxVal = minVal + 1;

      // Destroy existing slider if already created (safe re-init)
      if (slider.noUiSlider) {
        try {
          slider.noUiSlider.destroy();
        } catch (e) {
          // ignore
        }
      }

      try {
        noUiSlider.create(slider, {
          start: [minVal, maxVal],
          connect: true,
          range: { min: minVal, max: maxVal },
          format: {
            to: (value) => Math.round(value),
            from: (value) => Number(value),
          },
        });
      } catch (err) {
        console.error("noUiSlider error:", err);
        return;
      }

      const formatCurrency = new Intl.NumberFormat("es-AR", {
        style: "currency",
        currency: "ARS",
        maximumFractionDigits: 0,
      });

      // Set initial label
      if (label) {
        label.textContent = `${formatCurrency.format(minVal)} - ${formatCurrency.format(maxVal)}`;
      }

      slider.noUiSlider.on("update", function (values) {
        const [currentMin, currentMax] = values.map(Number);
        if (label) {
          label.textContent = `${formatCurrency.format(currentMin)} - ${formatCurrency.format(currentMax)}`;
        }

        // 1. En lugar de cambiar el display acá, filtramos la lista global
        filteredProducts = allProductsElements.filter((product) => {
          const price = parseFloat(product.dataset.price);
          if (!Number.isFinite(price)) return false;
          return price >= currentMin && price <= currentMax;
        });

        // 2. Cada vez que el filtro cambia, volvemos a la página 1
        currentPage = 1;

        // 3. Llamamos a nuestra nueva función que se encarga de mostrar los 15 (o 3) que correspondan
        updateUI();
      });
    }

    function initFilterToggle() {
      const toggle = document.querySelector(
        "#search_filters .text-uppercase.h6",
      );
      if (!toggle) return;

      const priceSection = document.querySelector(
        'section.facet[data-type="price"]',
      );
      const categorySection = document.querySelector(
        'section.facet[data-type="category"]',
      );
      const sections = [priceSection, categorySection].filter(Boolean);
      if (!sections.length) return;

      toggle.style.cursor = "pointer";

      function updateText(open) {
        toggle.textContent = open ? "Filtrar por Ʌ" : "Filtrar por";
      }

      function applyState(open) {
        sections.forEach((s) => {
          if (!s) return;
          s.style.display = open ? "" : "none";
        });
        updateText(open);
        toggle.dataset.open = open ? "true" : "false";
      }

      // Behavior: on large screens (>=768px) filters must always be visible
      function refreshBehaviour() {
        const isLarge = window.matchMedia("(min-width: 768px)").matches;

        if (isLarge) {
          applyState(true);
          // disable toggling on large screens
          toggle.onclick = null;
          toggle.style.pointerEvents = "none";
          toggle.style.opacity = "1";
        } else {
          // enable toggling on small screens
          toggle.style.pointerEvents = "";
          toggle.style.opacity = "";
          // default closed on small screens
          const initiallyOpen = false;
          applyState(initiallyOpen);
          toggle.onclick = function () {
            const isOpen = toggle.dataset.open === "true";
            applyState(!isOpen);
          };
        }
      }

      // initialize and keep in sync on resize
      refreshBehaviour();
      window.addEventListener("resize", function () {
        // debounce-like (simple)
        clearTimeout(window.__filterToggleResizeTimer);
        window.__filterToggleResizeTimer = setTimeout(refreshBehaviour, 120);
      });
    }

    // ---------- Ordenamiento de productos (cliente) ----------
    function getOrderFromQuery() {
      try {
        const qp = new URLSearchParams(window.location.search);
        const order = qp.get("order") || "";
        switch (order) {
          case "product.name.asc":
            return "name-asc";
          case "product.name.desc":
            return "name-desc";
          case "product.price.asc":
            return "price-asc";
          case "product.price.desc":
            return "price-desc";
          case "product.position.asc":
          default:
            return "relevance";
        }
      } catch (e) {
        return "relevance";
      }
    }

    function setOrderQuery(val) {
      try {
        const qp = new URLSearchParams(window.location.search);
        const map = {
          relevance: "product.position.asc",
          "name-asc": "product.name.asc",
          "name-desc": "product.name.desc",
          "price-asc": "product.price.asc",
          "price-desc": "product.price.desc",
        };
        qp.set("order", map[val] || "product.position.asc");
        const url = `${window.location.pathname}?${qp.toString()}`;
        window.history.replaceState({}, "", url);
      } catch (e) {
        // ignore
      }
    }

    function sortProducts(criteria) {
      const container = document.querySelector("#js-product-list .products");
      if (!container) return;
      const items = Array.from(container.querySelectorAll(".js-product"));

      const collator = new Intl.Collator("es", {
        sensitivity: "base",
        numeric: true,
      });

      items.sort((a, b) => {
        if (criteria === "name-asc" || criteria === "name-desc") {
          const an = (
            a.querySelector(".product-title a")?.textContent || ""
          ).trim();
          const bn = (
            b.querySelector(".product-title a")?.textContent || ""
          ).trim();
          const cmp = collator.compare(an, bn);
          return criteria === "name-asc" ? cmp : -cmp;
        }

        if (criteria === "price-asc" || criteria === "price-desc") {
          const ap = Number(a.dataset.price) || 0;
          const bp = Number(b.dataset.price) || 0;
          return criteria === "price-asc" ? ap - bp : bp - ap;
        }

        // relevance (default) - use numeric data-relevance
        const ar = Number(a.dataset.relevance) || 0;
        const br = Number(b.dataset.relevance) || 0;
        return ar - br;
      });

      // Re-append in sorted order
      for (const it of items) container.appendChild(it);

      const slider = document.getElementById("price-slider");
      const [min, max] = slider.noUiSlider.get().map(Number);

      filteredProducts = items.filter((el) => {
        const price = parseFloat(el.dataset.price);
        return price >= min && price <= max;
      });

      currentPage = 1;
      updateUI();
    }

    function initSorting() {
      const select = document.getElementById("products-sort-select");
      if (!select) return;
      // set initial value from query
      const initial = getOrderFromQuery();
      select.value = initial;
      sortProducts(initial);

      select.addEventListener("change", function () {
        const v = select.value;
        setOrderQuery(v);
        sortProducts(v);
      });
    }

    // 1. Configuraciones base
    const ITEMS_PER_PAGE = 12;
    let currentPage = 1;
    const productsSection = document.getElementById("products");

    // 2. Guardamos todos los productos en un Array desde el principio.
    // Usamos Array.from para convertir el NodeList en un Array real de JS y poder manipularlo fácil.
    const allProductsElements = Array.from(
      document.querySelectorAll(".js-product"),
    );

    // 3. Esta variable va a tener los productos "activos" (los que cumplen los filtros).
    // Al cargar la página por primera vez, son todos.
    let filteredProducts = [...allProductsElements];

    function renderPage(page) {
      // 1. Calculamos los índices matemáticos
      const startIndex = (page - 1) * ITEMS_PER_PAGE;
      const endIndex = startIndex + ITEMS_PER_PAGE;

      // 2. Primero, por las dudas, ocultamos ABSOLUTAMENTE TODOS los productos en el DOM
      allProductsElements.forEach((el) => (el.style.display = "none"));

      // 3. Agarramos solo nuestra lista de "productos válidos/filtrados"
      // y mostramos los que caen dentro del rango de esta página
      filteredProducts.forEach((el, index) => {
        if (index >= startIndex && index < endIndex) {
          el.style.display = "block";
        }
      });
    }
    function setupPagination() {
      const paginationContainer = document.getElementById(
        "pagination-container",
      );
      paginationContainer.innerHTML = ""; // Limpiamos el contenedor

      const pageCount = Math.ceil(filteredProducts.length / ITEMS_PER_PAGE);

      // Si solo hay una página, no mostramos los controles
      if (pageCount <= 1) return;

      // --- Botón ANTERIOR ---
      const prevLi = document.createElement("li");
      prevLi.className = `page-item ${currentPage === 1 ? "disabled" : ""}`;
      prevLi.innerHTML = `<a class="page-link prev js-search-link" href="#">Anterior</a>`;
      prevLi.onclick = (e) => {
        e.preventDefault();
        if (currentPage > 1) {
          currentPage--;
          updateUI();
          if (productsSection) {
            productsSection.scrollIntoView({
              behavior: "smooth",
              block: "start",
            });
          } else {
            window.scrollTo({ top: 0, behavior: "smooth" });
          }
        }
      };
      paginationContainer.appendChild(prevLi);

      // --- Botones NUMÉRICOS ---
      for (let i = 1; i <= pageCount; i++) {
        const li = document.createElement("li");
        // Agregamos la clase 'active' o 'current' según tus estilos en theme.css
        li.className = `page-item ${currentPage === i ? "active current" : ""}`;
        li.innerHTML = `<a class="page-link js-search-link" href="#">${i}</a>`;

        li.onclick = (e) => {
          e.preventDefault();
          currentPage = i;
          updateUI();
          if (productsSection) {
            productsSection.scrollIntoView({
              behavior: "smooth",
              block: "start",
            });
          } else {
            window.scrollTo({ top: 0, behavior: "smooth" });
          }
        };
        paginationContainer.appendChild(li);
      }

      // --- Botón SIGUIENTE ---
      const nextLi = document.createElement("li");
      nextLi.className = `page-item ${currentPage === pageCount ? "disabled" : ""}`;
      nextLi.innerHTML = `<a class="page-link next js-search-link" href="#">Siguiente</a>`;
      nextLi.onclick = (e) => {
        e.preventDefault();
        if (currentPage < pageCount) {
          currentPage++;
          updateUI();
          if (productsSection) {
            productsSection.scrollIntoView({
              behavior: "smooth",
              block: "start",
            });
          } else {
            window.scrollTo({ top: 0, behavior: "smooth" });
          }
        }
      };
      paginationContainer.appendChild(nextLi);
    }

    function updateUI() {
      renderPage(currentPage);
      setupPagination();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", function () {
        initSlider();
        initFilterToggle();
        initSorting();
        updateUI();
      });
    } else {
      initSlider();
      initFilterToggle();
      initSorting();
      updateUI();
    }
  </script>

  <style>
    /* Personalización rápida para que combine con tu sitio */
    .products-sort-order {
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }
    .products-sort-select {
      background: transparent;
      border: 1px solid rgba(0, 0, 0, 0.12);
      padding: 8px 12px;
      border-radius: 4px;
      font-size: 14px;
      color: #222;
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
      background-image:
        linear-gradient(45deg, transparent 50%, #666 50%),
        linear-gradient(135deg, #666 50%, transparent 50%);
      background-position:
        calc(100% - 18px) calc(1em + 2px),
        calc(100% - 13px) calc(1em + 2px);
      background-size:
        5px 5px,
        5px 5px;
      background-repeat: no-repeat;
      cursor: pointer;
    }
    @media (max-width: 767px) {
      .products-sort-order {
        justify-content: center;
        margin: 0.5rem 0;
      }
    }
    /* Fix: tarjetas de producto con altura uniforme */
    .products .js-product {
      display: flex;
    }
    .product-miniature {
      display: flex;
      flex-direction: column;
      height: 420px; /* altura fija por defecto */
      overflow: hidden;
      background: #fff;
      border-radius: 6px;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    }
    .thumbnail-container {
      display: flex;
      flex-direction: column;
      flex: 0 0 auto;
    }
    .thumbnail-top {
      height: 250px; /* espacio reservado para la imagen */
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .thumbnail-top img {
      width: auto;
      max-width: 100%;
      height: 100%;
      object-fit: contain;
      padding-top: 0 !important; /* anula inline style */
      display: block;
    }
    .product-description {
      padding: 12px;
      flex: 1 1 auto;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    @media (max-width: 767px) {
      .product-miniature {
        height: auto;
      }
      .thumbnail-top {
        height: 200px;
      }
    }
    :global(.noUi-connect) {
      background: #2fb5d2; /* El color cyan de PrestaShop o el de tu marca */
    }
    :global(.noUi-horizontal) {
      height: 8px;
    }
    :global(.noUi-handle) {
      height: 18px !important;
      width: 18px !important;
      border-radius: 50%;
      cursor: pointer;
      box-shadow: none;
    }
    :global(.noUi-handle:before, .noUi-handle:after) {
      display: none; /* Quita las rayitas feas del handle */
    }

    @media (max-width: 767px) {
      #search_filters_wrapper {
        display: block !important;
        margin: 10px 0;
        width: 100%;
      }
    }
  </style>
</LayoutListado>
